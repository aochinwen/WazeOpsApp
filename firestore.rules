rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // CCTV health records - written only by Firebase Admin SDK (scheduled function)
    // Read is public since there is no sensitive data (camera IDs, status, response times only)
    match /cctv_health/{cameraId} {
      allow read: if true;
      allow write: if false;
    }

    // LTA notification dedup records - internal use only
    match /sent_lta_notifications/{docId} {
      allow read, write: if false;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
