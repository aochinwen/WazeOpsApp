# Gemini API Key (Required for AI features)
# Get one at https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Backend Service Key (Required for notification security)
# This key is used to authenticate requests to the notification service
API_KEY=your_secret_api_key_here

# Frontend API Key (Required for client-side API calls)
# Used by the frontend to authenticate with the backend
VITE_API_KEY=your_secret_api_key_here

# Frontend URL (Optional)
# The URL where the frontend is deployed (e.g., https://username.github.io/WazeOpsApp)
# Defaults to http://localhost:3000 if not set
FRONTEND_URL=http://localhost:3000

# Frontend URL for Vite (Optional)
# Used by Vite build process for generating correct URLs
VITE_FRONTEND_URL=http://localhost:3000

# Backend URL (Required)
# The URL of the backend service (used by frontend to fetch data)
# Defaults to http://localhost:3001 if not set
VITE_BACKEND_URL=http://localhost:3001

# Notification Service URL (Optional)
# The URL of the downstream notification service
# Defaults to http://localhost:3002/api/notify if not set
NOTIFY_URL=http://localhost:3002/api/notify

# Mapbox Token (Required for map display)
# Get one at https://account.mapbox.com/
VITE_MAPBOX_TOKEN=your_mapbox_token_here

# LTA DataMall API Key (Optional - for Singapore traffic data)
# Get one at https://datamall.lta.gov.sg/content/datamall/en/request-for-api.html
DATAMALL_API_KEY=your_lta_api_key_here
